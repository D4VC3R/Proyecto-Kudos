            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Demo\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
            },
            "url": "{{baseUrl}}/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.access_token) { pm.collectionVariables.set('token', json.data.access_token); }",
